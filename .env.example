# ─── Nexus Alpha — Environment Variables ─────────────────────────────────────
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to Git.

# ─── Authentication ────────────────────────────────────────────────────────────
# Strong random string (min 32 chars). Generate: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# Simple passcode for quick login
OWNER_PASSCODE=nexus2026

# Email login
OWNER_EMAIL=admin@nexusalpha.ai
OWNER_PASSWORD=YourStrongPassword123

# OR use bcrypt hash for max security (recommended in production):
# Generate: node -e "const b=require('bcryptjs'); console.log(b.hashSync('YourPassword', 12))"
# OWNER_PASSWORD_HASH=$2a$12$...

# ─── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ─── Data Source (server-only — do NOT prefix with NEXT_PUBLIC_) ──────────────
DATA_SOURCE=MOCK

# ─── Database (optional) ──────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@host/db

# ─── Redis (optional) ─────────────────────────────────────────────────────────
# UPSTASH_REDIS_URL=https://...
# UPSTASH_REDIS_TOKEN=...

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
